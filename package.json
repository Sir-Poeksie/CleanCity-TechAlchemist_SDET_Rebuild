{
  "name": "cleancity-waste-scheduler",
  "version": "2.0.0",
  "description": "Enterprise SDET-Ready Web App for QA Engineers – CleanCity Waste Pickup Scheduler",
  "private": true,
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test:unit": "jest --runInBand --coverage --reporters=default --reporters=jest-html-reporter",
    "test:e2e": "cypress run --browser chrome --reporter mochawesome",
    "test:ci": "npm run test:unit && npm run test:e2e",
    "cypress:open": "cypress open",
    "report:merge": "npx mochawesome-merge mochawesome-report/*.json > mochawesome-report/output.json",
    "report:generate": "npx mochawesome-report-generator mochawesome-report/output.json",
    "lint": "eslint src --max-warnings=0",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\"",
    "audit": "npm audit --production"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.3.0",
    "@testing-library/user-event": "^13.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.3.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "cypress": "^14.5.1",
    "cypress-cucumber-preprocessor": "^4.3.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.4",
    "jest-html-reporter": "^4.3.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0",
    "axe-core": "^4.8.3"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["<rootDir>/src/_tests_/setupTests.js"]
  },
  "eslintConfig": {
    "extends": ["react-app", "react-app/jest"]
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  },
  "homepage": "."
}
